    {
        // Arrange
        using var context = new ValoraDbContext(CreateOptions());
        var repository = new NeighborhoodRepository(context);
        var neighborhood = new Neighborhood { Code = "BU001", Name = "Test", City = "Amsterdam", Type = "Buurt" };

        // Act
