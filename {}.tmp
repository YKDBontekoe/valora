                    b.HasIndex("WorkspaceId", "InvitedEmail")
                        .IsUnique()
                        .HasFilter("\"InvitedEmail\" IS NOT NULL");

                    b.HasIndex("WorkspaceId", "UserId")
                        .IsUnique()
                        .HasFilter("\"UserId\" IS NOT NULL");

                    b.ToTable("WorkspaceMembers");
                });

